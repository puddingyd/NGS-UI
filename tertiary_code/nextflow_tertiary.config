 * direct, indirect, or consequential damages arising from
 * its use.
 * =========================================================
 * nextflow_tertiary.config
 * ========================
 * 三級分析 Nextflow 設定檔
 *
 * 路徑設計原則（與二級 config 相同模式）：
 *   - profiles 設定各環境的根目錄（ref_dir、sif_dir 等）
 *   - profiles 之後的 params {} 從根目錄推導其他路徑
 *   - 推導用的 params {} 裡不能再宣告 ref_dir = null，
 *     否則會把 profile 設好的值蓋回 null
 *
 * LOFTEE gerp workaround：
 *   LOFTEE 的 gerp_dist.pl 有 bug，將 loftee_path 直接與檔名拼接（無 /），
 *   解決方式是透過 --bind 把 gerp bw 直接掛載至 /opt/vep/Plugins/gerp_...bw
 *   此 bind 在 VEP_ANNOTATE process 的 containerOptions 裡設定
 */

apptainer {
    enabled    = true
    autoMounts = true
}

// ── Step 1：各環境只需設定根目錄 ─────────────────────────────

profiles {

    local {
        params {
            ref_dir     = "/scratch/pylin1991/GenomicReference_Cache/hg38"
            sif_dir     = "/data/pylin1991/nf-containers"
            scripts_dir = "/data/pylin1991/nf-containers/NGStertiary/1_0_0/scripts"
            out_dir     = "/scratch/pylin1991/tertiary_test"

            apptainer_base_opts = "--bind /scratch,/data"
            use_gpu_pangolin    = true
            use_gpu_evo2        = true
        }

        apptainer {
            runOptions = "--bind /scratch,/data"
        }

        process {
            withLabel: process_low    { cpus = 2;  memory = 8.GB  }
            withLabel: process_medium { cpus = 8;  memory = 32.GB }
            withLabel: process_high   { cpus = 16; memory = 64.GB }
            withLabel: process_gpu {
                containerOptions = "--nv"
                maxForks = 1
            }
        }
    }

    dgm {
        params {
            ref_dir     = "/home/pipeline/reference/hg38"
            sif_dir     = "/home/pipeline/nextflow_containers"
            scripts_dir = "/home/pipeline/tertiary_code/scripts"
            out_dir     = "/home/pipeline/tertiary_output"

            apptainer_base_opts = "--bind /home"
            use_gpu_pangolin    = true
            use_gpu_evo2        = false
        }

        apptainer {
            runOptions = "--bind /home"
        }

        process {
            withLabel: process_low    { cpus = 2;  memory = 8.GB  }
            withLabel: process_medium { cpus = 8;  memory = 32.GB }
            withLabel: process_high   { cpus = 32; memory = 64.GB }
            withLabel: process_gpu {
                containerOptions = "--nv"
                maxForks = 1
            }
        }
    }
}

// ── Step 2：從根目錄推導所有路徑 ─────────────────────────────
// 注意：這裡不宣告 ref_dir / sif_dir / scripts_dir，
//       否則會把 profile 設好的值蓋回 null

params {
    // 必填（執行時傳入）
    sample_id   = null
    input_dir   = null
    out_dir     = null

    // 分析選項
    seq_type    = "WES"
    hpo         = ""
    run_evo2    = false
    run_phasing = false

    // 共用 Reference（從 ref_dir 推導）
    ref_fasta    = "${params.ref_dir}/Homo_sapiens_assembly38.fasta"

    // 三級分析專用資料庫（從 ref_dir/tertiary 推導）
    tertiary_dir = "${params.ref_dir}/tertiary"
    vep_cache    = "${params.ref_dir}/tertiary/vep_cache"
    dbnsfp       = "${params.ref_dir}/tertiary/dbnsfp/dbNSFP4.9c_grch38.gz"
    loftee_dir   = "${params.ref_dir}/tertiary/loftee"
    clinvar      = "${params.ref_dir}/tertiary/clinvar/clinvar_20260418.vcf.gz"
    gnomad_dir   = "${params.ref_dir}/tertiary/gnomad"
    pangolin_db  = "${params.ref_dir}/tertiary/pangolin/gencode.v47.annotation.db"
    strchive     = "${params.ref_dir}/tertiary/strchive/STRchive-loci.json"
    mitomap_dir  = "${params.ref_dir}/tertiary/mitomap"

    // GPU / Apptainer 選項預設值（profile 可覆蓋）
    apptainer_base_opts = null
    use_gpu_pangolin    = false
    use_gpu_evo2        = false
}

// ── 執行報告 ──────────────────────────────────────────────────

report   { enabled = true; file = "${params.out_dir}/pipeline_info/execution_report.html";   overwrite = true }
timeline { enabled = true; file = "${params.out_dir}/pipeline_info/execution_timeline.html"; overwrite = true }
trace    { enabled = true; file = "${params.out_dir}/pipeline_info/execution_trace.txt";     overwrite = true }
